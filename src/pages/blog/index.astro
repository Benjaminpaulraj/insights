---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import placeholder1 from '../../assets/blog-placeholder-1.jpg';
import placeholder2 from '../../assets/blog-placeholder-2.jpg';
import placeholder3 from '../../assets/blog-placeholder-3.jpg';
import placeholder4 from '../../assets/blog-placeholder-4.jpg';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const presentations = [
	{
		title: 'How Claude CLI Agent Works — Interactive Architecture',
		description:
			'A visual walkthrough of every layer inside Claude CLI: tools, sub-agents, memory, and permissions.',
		pubDate: new Date('2026-05-24'),
		href: `${base}claude-cli-architecture.html`,
		heroImage: placeholder4,
		gcPath: '/insights/claude-cli-architecture.html',
	},
	{
		title: 'The Complete History of Money — Visual Guide',
		description:
			'From seashells to digital dollars — how humanity invented and reinvented money across the centuries.',
		pubDate: new Date('2026-05-02'),
		href: `${base}currency-visual.html`,
		heroImage: placeholder3,
		gcPath: '/insights/currency-visual.html',
	},
	{
		title: "How Claude's Memory Works — Visual Guide",
		description:
			"11 context management strategies explained visually. Understand what fits inside Claude's 200K token window.",
		pubDate: new Date('2026-04-27'),
		href: `${base}claude-context-visual-guide.html`,
		heroImage: placeholder3,
		gcPath: '/insights/claude-context-visual-guide.html',
	},
	{
		title: 'Mastering Claude Context Management',
		description:
			'A 25-slide deep dive into LLM limitations, context windows, and extended thinking — for developers and curious readers alike.',
		pubDate: new Date('2026-04-27'),
		href: `${base}claude-context-presentation.html`,
		heroImage: placeholder2,
		gcPath: '/insights/claude-context-presentation.html',
	},
	{
		title: 'Why Every Great Empire Eventually Falls — Visual Framework',
		description:
			"Glubb's 5-stage empire cycle visualised. See where America, China, and other powers stand today.",
		pubDate: new Date('2026-04-27'),
		href: `${base}empire-cycle-diagram.html`,
		heroImage: placeholder1,
		gcPath: '/insights/empire-cycle-diagram.html',
	},
	{
		title: 'The Petrodollar System — Visual Explainer',
		description:
			'How oil pricing in dollars fuels US economic dominance — the full petrodollar loop in one visual guide.',
		pubDate: new Date('2026-04-27'),
		href: `${base}petrodollar-visual.html`,
		heroImage: placeholder2,
		gcPath: '/insights/petrodollar-visual.html',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.views {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				margin: 0.2rem 0 0;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						presentations.map((item) => (
							<li>
								<a href={item.href}>
									<Image width={720} height={360} src={item.heroImage} alt="" />
									<h4 class="title">{item.title}</h4>
									<p class="date">
										<FormattedDate date={item.pubDate} />
									</p>
									<p class="views" data-gc-path={item.gcPath}></p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			document.querySelectorAll<HTMLElement>('[data-gc-path]').forEach(async (el) => {
				const path = el.dataset.gcPath!;
				try {
					const res = await fetch(
						`https://benjaminpaulraj.goatcounter.com/counter/${encodeURIComponent(path)}.json`
					);
					if (!res.ok) return;
					const { count } = await res.json();
					if (count && count !== '0') el.textContent = `${count} views`;
				} catch {}
			});
		</script>
	</body>
</html>
