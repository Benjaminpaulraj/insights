---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const dailyWords = (await getCollection('blog'))
	.filter((post) => post.id.match(/^\d{4}-\d{2}-\d{2}-word-/))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Daily Word — ${SITE_TITLE}`} description="One word, explained properly, every day." />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.page-header {
				padding: 2.5rem 0 2rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2rem;
			}
			.page-header h1 {
				font-size: 2rem;
				margin: 0 0 0.5rem;
			}
			.page-header p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			li:last-child {
				border-bottom: none;
			}
			li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				padding: 1.1rem 0;
				text-decoration: none;
				color: rgb(var(--black));
				gap: 1rem;
				transition: color 0.15s ease;
			}
			li a:hover {
				color: rgb(var(--accent));
			}
			.word-title {
				font-size: 1.05rem;
				font-weight: 600;
				margin: 0;
			}
			.word-desc {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0.25rem 0 0;
			}
			.date {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}
			.empty {
				color: rgb(var(--gray));
				font-size: 1rem;
				padding: 2rem 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Daily Word</h1>
				<p>One word, explained properly, every day.</p>
			</div>
			{dailyWords.length === 0 ? (
				<p class="empty">No daily words yet — check back soon.</p>
			) : (
				<ul>
					{dailyWords.map((post) => {
						const word = post.data.title.replace(/^Word of the Day:\s*/i, '').trim();
						return (
							<li>
								<a href={`${base}blog/${post.id}/`}>
									<div>
										<p class="word-title">{word}</p>
										<p class="word-desc">{post.data.description}</p>
									</div>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						);
					})}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
