---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import TagBadge from '../../components/TagBadge.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);

	const tagSet = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			tagSet.add(tag.toLowerCase());
		}
	}

	return [...tagSet].map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((p) => p.data.tags?.map((t) => t.toLowerCase()).includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

interface Props {
	tag: string;
	posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const displayTag = posts[0]?.data.tags?.find((t) => t.toLowerCase() === tag) ?? tag;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`#${displayTag} — ${SITE_TITLE}`}
			description={`Articles tagged with #${displayTag}`}
		/>
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3em 1em;
			}
			.tag-header {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			h1 {
				font-size: 2rem;
				margin: 0;
			}
			.back {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.back:hover {
				color: var(--accent);
			}
			.count {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.post-item a {
				display: block;
				padding: 1.25rem;
				border-radius: 8px;
				text-decoration: none;
				color: inherit;
				transition: background 0.15s;
			}
			.post-item a:hover {
				background: rgba(var(--gray-light), 0.5);
			}
			.post-meta {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				margin-bottom: 0.3rem;
			}
			.post-title {
				font-size: 1.1rem;
				font-weight: 700;
				margin: 0 0 0.3rem;
				line-height: 1.3;
			}
			.post-item a:hover .post-title {
				color: var(--accent);
			}
			.post-desc {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0 0 0.5rem;
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a href={`${base}tags/`} class="back">← All tags</a>
			<div class="tag-header">
				<h1>#{displayTag}</h1>
			</div>
			<p class="count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
			<ul class="post-list">
				{posts.map(post => (
					<li class="post-item">
						<a href={`${base}blog/${post.id}/`}>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-desc">{post.data.description}</p>
							{post.data.tags && (
								<div class="post-tags">
									{post.data.tags.map(t => <TagBadge tag={t} />)}
								</div>
							)}
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
