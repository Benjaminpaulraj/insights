---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2rem 1rem 4rem;
			}
			.hero {
				padding: 3rem 0 2rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5rem;
			}
			.hero h1 {
				font-size: 2.8rem;
				line-height: 1.15;
				margin: 0 0 1rem;
			}
			.hero p {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				margin: 0 0 1.5rem;
				line-height: 1.6;
			}
			.cta {
				display: inline-block;
				background: rgb(var(--accent));
				color: white;
				padding: 0.65rem 1.4rem;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				transition: opacity 0.2s ease;
			}
			.cta:hover {
				opacity: 0.85;
			}
			.topics {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
				margin-top: 1rem;
			}
			.topic {
				padding: 1.25rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
			}
			.topic h3 {
				margin: 0 0 0.5rem;
				font-size: 1rem;
			}
			.topic p {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				line-height: 1.5;
			}
			h2 {
				font-size: 1.2rem;
				margin: 0 0 1rem;
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 600px) {
				.hero h1 {
					font-size: 2rem;
				}
				.topics {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Ideas worth understanding.</h1>
				<p>
					I write about AI, geopolitics, and economics — the systems that quietly shape
					everything. Each post breaks down one big idea in plain English, with visuals
					that make it stick.
				</p>
				<a href={`${base}blog`} class="cta">Read the blog</a>
			</section>

			<section>
				<h2>What's on here</h2>
				<div class="topics">
					<div class="topic">
						<h3>Artificial Intelligence</h3>
						<p>How AI systems actually work — from context windows to agent architectures — explained without the hype.</p>
					</div>
					<div class="topic">
						<h3>Geopolitics</h3>
						<p>Why empires rise and fall, how global power shifts, and what history tells us about where we're headed.</p>
					</div>
					<div class="topic">
						<h3>Economics</h3>
						<p>The hidden mechanics of money, oil, debt, and trade — and why they matter more than most people realise.</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
